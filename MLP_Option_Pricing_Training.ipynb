        "# ==============================================================================\n",
        "# CELL 8 — EVALUATION & BENCHMARKING\n",
        "# ==============================================================================\n",
        "\n",
        "def compute_metrics(y_true, y_pred):\n",
        "    \"\"\"Ke & Yang (2019) Table 1 metrics.\"\"\"\n",
        "    mask = y_true > 0.01\n",
        "    yt, yp = y_true[mask], y_pred[mask]\n",
        "    pct_err = (yp - yt) / yt * 100\n",
        "    abs_pct = np.abs(pct_err)\n",
        "    return {\n",
        "        'MSE':   float(np.mean((yp - yt)**2)),\n",
        "        'Bias':  float(np.median(pct_err)),\n",
        "        'AAPE':  float(np.mean(abs_pct)),\n",
        "        'MAPE':  float(np.median(abs_pct)),\n",
        "        'PE5%':  float(np.mean(abs_pct <= 5)  * 100),\n",
        "        'PE10%': float(np.mean(abs_pct <= 10) * 100),\n",
        "        'PE20%': float(np.mean(abs_pct <= 20) * 100),\n",
        "    }\n",
        "\n",
        "\n",
        "# Set to None for the full test set, or an integer for a quick run\n",
        "N_EVAL = None\n",
        "\n",
        "results_all = []\n",
        "\n",
        "for opt_type in ['call', 'put']:\n",
        "    if opt_type not in data_splits:\n",
        "        continue\n",
        "    split = data_splits[opt_type]\n",
        "    Y_test = split['Y_test']\n",
        "    y_true = (Y_test[:, 0] + Y_test[:, 1]) / 2.0\n",
        "\n",
        "    total = len(split['test_df'])\n",
        "    if N_EVAL is None or N_EVAL >= total:\n",
        "        eval_idx = np.arange(total)\n",
        "        n_eval = total\n",
        "    else:\n",
        "        eval_idx = np.random.RandomState(42).choice(total, N_EVAL, replace=False)\n",
        "        n_eval = N_EVAL\n",
        "\n",
        "    edf = split['test_df'].iloc[eval_idx].reset_index(drop=True)\n",
        "    e_true = y_true[eval_idx]\n",
        "\n",
        "    print(f\"\\n── {opt_type.upper()} (eval on {n_eval:,} samples) ──\")\n",
        "\n",
        "    model = models[opt_type]; model.eval()\n",
        "    X_sub = split['X_test'][eval_idx]\n",
        "    with torch.no_grad():\n",
        "        pred = model(torch.tensor(X_sub, dtype=torch.float32)\n",
        "                     .to(DEVICE)).cpu().numpy()\n",
        "    mlp2_mid = (pred[:, 0] + pred[:, 1]) / 2.0\n",
        "    m = compute_metrics(e_true, mlp2_mid)\n",
        "    m.update({'Model': 'MLP2 (ours)', 'Type': opt_type})\n",
        "    results_all.append(m)\n",
        "    print(f\" {'MLP2':20s}: MSE={m['MSE']:.2f} MAPE={m['MAPE']:.2f}% PE5={m['PE5%']:.1f}%\")\n",
        "\n",
        "    # Input arrays\n",
        "    S_arr = edf['S'].values\n",
        "    K_arr = edf['K'].values\n",
        "    T_arr = edf['T'].values\n",
        "    r_arr = edf['r'].values\n",
        "    hist_vol_arr = edf['sigma'].values / 100.0  # convert % from our data set to decimal\n",
        "\n",
        "\n",
        "    for bm_name, fn in [\n",
        "        ('Black-Scholes',    lambda: black_scholes(S_arr, K_arr, T_arr, r_arr, hist_vol_arr, opt_type)),\n",
        "        ('Binomial (N=200)', lambda: binomial_tree(S_arr, K_arr, T_arr, r_arr, hist_vol_arr, opt_type, N=200)),\n",
        "        ('Monte Carlo 10k',  lambda: monte_carlo(  S_arr, K_arr, T_arr, r_arr, hist_vol_arr, opt_type, n_sims=5000)),\n",
        "        ('Heston MC',        lambda: heston_mc(    S_arr, K_arr, T_arr, r_arr, hist_vol_arr, opt_type, n_sims=2000, n_steps=50)),\n",
        "    ]:\n",
        "        t0 = time.time()\n",
        "        preds = fn()\n",
        "        elapsed = time.time() - t0\n",
        "        valid = np.isfinite(preds)\n",
        "        if valid.sum() < 10:\n",
        "            continue\n",
        "        m = compute_metrics(e_true[valid], preds[valid])\n",
        "        m.update({'Model': bm_name, 'Type': opt_type, 'Time_s': elapsed})\n",
        "        results_all.append(m)\n",
        "        print(f\" {bm_name:20s}: MSE={m['MSE']:.2f} MAPE={m['MAPE']:.2f}% \"\n",
        "              f\"PE5={m['PE5%']:.1f}% ({elapsed:.1f}s)\")\n",
        "\n",
        "results_df = pd.DataFrame(results_all)\n",
        "results_df.to_csv(os.path.join(MODEL_SAVE_DIR, 'results.csv'), index=False)\n",
        "print(f\"\\n{results_df.to_string(index=False, float_format='%.2f')}\")\n",
        "\n"
