        "# ==============================================================================\n",
        "# CELL 12 — SPEED BENCHMARK\n",
        "# ==============================================================================\n",
        "\n",
        "def benchmark_speed(n=1000):\n",
        "    rng = np.random.RandomState(42)\n",
        "    S = rng.uniform(50, 500, n)\n",
        "    K = S * rng.uniform(0.8, 1.2, n)\n",
        "    T = rng.uniform(0.05, 2.0, n)\n",
        "    r = rng.uniform(0.01, 0.06, n)\n",
        "    sig = rng.uniform(0.1, 0.6, n)\n",
        "    timings = {}\n",
        "\n",
        "    t0 = time.time()\n",
        "    for i in range(n): black_scholes(S[i],K[i],T[i],r[i],sig[i])\n",
        "    timings['Black-Scholes'] = (time.time()-t0)/n*1000\n",
        "\n",
        "    t0 = time.time()\n",
        "    for i in range(200): binomial_tree(S[i],K[i],T[i],r[i],sig[i])\n",
        "    timings['Binomial'] = (time.time()-t0)/200*1000\n",
        "\n",
        "    t0 = time.time()\n",
        "    for i in range(100): monte_carlo(S[i],K[i],T[i],r[i],sig[i])\n",
        "    timings['Monte Carlo'] = (time.time()-t0)/100*1000\n",
        "\n",
        "    t0 = time.time()\n",
        "    for i in range(50): heston_mc(S[i],K[i],T[i],r[i],sig[i])\n",
        "    timings['Heston MC'] = (time.time()-t0)/50*1000\n",
        "\n",
        "    if 'call' in models:\n",
        "        sc = data_splits['call']['scaler']\n",
        "        n_feat = len(FEATURE_COLS)\n",
        "        feats = np.zeros((n, n_feat), dtype=np.float32)\n",
        "        feats[:, 0] = S;  feats[:, 1] = K;  feats[:, 2] = T\n",
        "        feats[:, 3] = r;  feats[:, 4] = sig\n",
        "        feats[:, 5] = S/K; feats[:, 6] = np.log(S/K); feats[:, 7] = sig\n",
        "        feats = sc.transform(feats)\n",
        "        models['call'].eval()\n",
        "        t0 = time.time()\n",
        "        with torch.no_grad():\n",
        "            _ = models['call'](torch.tensor(feats).to(DEVICE))\n",
        "        timings['MLP2 (batch)'] = (time.time()-t0)/n*1000\n",
        "\n",
        "    print(f\"\\n{'Model':<20} {'ms/option':>10}\")\n",
        "    print('-'*32)\n",
        "    for k, v in sorted(timings.items(), key=lambda x: x[1]):\n",
        "        print(f\"{k:<20} {v:>10.4f}\")\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(8, 4))\n",
        "    names = list(timings.keys())\n",
        "    vals = [timings[n] for n in names]\n",
        "    colors = ['#4CAF50' if 'MLP2' in n else '#2196F3' for n in names]\n",
        "    ax.barh(names, vals, color=colors, alpha=0.8)\n",
        "    ax.set_xlabel('ms / option'); ax.set_xscale('log')\n",
        "    ax.set_title('Computational Speed Comparison')\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(os.path.join(MODEL_SAVE_DIR, 'speed.png'), dpi=150)\n",
        "    plt.show()\n",
        "\n",
        "benchmark_speed()"
      ]
    },
