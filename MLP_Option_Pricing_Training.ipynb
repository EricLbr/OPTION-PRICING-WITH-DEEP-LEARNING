        "# ==============================================================================\n",
        "# CELL 6 — TRAINING WITH CHECKPOINTING\n",
        "# ==============================================================================\n",
        "\n",
        "def train_mlp2(data, model_name, device=DEVICE):\n",
        "    \"\"\"\n",
        "    Train MLP2 with Ke & Yang protocol + phase-level checkpointing.\n",
        "    \"\"\"\n",
        "    LR_SCHEDULE = [(30, 1e-3), (10, 1e-4), (10, 1e-5), (10, 1e-6)]\n",
        "    BATCH_SIZE = 4096\n",
        "    total_epochs = sum(e for e, _ in LR_SCHEDULE)\n",
        "\n",
        "    input_dim = data['X_train'].shape[1]\n",
        "    checkpoint_path = os.path.join(MODEL_SAVE_DIR, f'{model_name}_checkpoint.pt')\n",
        "    final_path = os.path.join(MODEL_SAVE_DIR, f'{model_name}_final.pt')\n",
        "\n",
        "    model = MLP2(input_dim).to(device)\n",
        "    start_phase = 0\n",
        "    history = {'train_loss': [], 'val_loss': []}\n",
        "\n",
        "    if os.path.exists(checkpoint_path):\n",
        "        ckpt = torch.load(checkpoint_path, map_location=device, weights_only=False)\n",
        "        model.load_state_dict(ckpt['model_state'])\n",
        "        start_phase = ckpt['phase'] + 1\n",
        "        history = ckpt.get('history', history)\n",
        "        print(f\"  Resumed from checkpoint (completed phase {ckpt['phase']})\")\n",
        "\n",
        "    if start_phase >= len(LR_SCHEDULE):\n",
        "        if os.path.exists(final_path):\n",
        "            model.load_state_dict(torch.load(final_path, map_location=device, weights_only=False))\n",
        "        print(f\"  ✓ {model_name} already fully trained ({len(history['train_loss'])} epochs in \"\n",
        "              f\"history) — loaded final model, skipping training.\")\n",
        "        return model, history\n",
        "\n",
        "    if os.path.exists(final_path) and not os.path.exists(checkpoint_path):\n",
        "        model.load_state_dict(torch.load(final_path, map_location=device, weights_only=False))\n",
        "        print(f\"  ⚠ Final model found for {model_name}, but no checkpoint file — loss \"\n",
        "              f\"history is unavailable for plotting. Loaded final weights, skipping training.\")\n",
        "        return model, history\n",
        "\n",
        "    print(\"  Moving data to GPU for direct native slicing...\")\n",
        "\n",
        "    # Move everything to GPU\n",
        "    X_train_gpu = torch.tensor(data['X_train'], dtype=torch.float32, device=device)\n",
        "    Y_train_gpu = torch.tensor(data['Y_train'], dtype=torch.float32, device=device)\n",
        "    X_val_gpu = torch.tensor(data['X_val'], dtype=torch.float32, device=device)\n",
        "    Y_val_gpu = torch.tensor(data['Y_val'], dtype=torch.float32, device=device)\n",
        "\n",
        "    n_train = len(X_train_gpu)\n",
        "    n_val = len(X_val_gpu)\n",
        "\n",
        "    criterion = nn.MSELoss()\n",
        "    global_epoch = sum(e for e, _ in LR_SCHEDULE[:start_phase])\n",
        "\n",
        "    print(f\"  {model_name} | input={input_dim} | params={sum(p.numel() for p in model.parameters()):,} | train={n_train:,}\")\n",
        "\n",
        "    for phase_idx, (n_epochs, lr) in enumerate(LR_SCHEDULE):\n",
        "        if phase_idx < start_phase: continue\n",
        "\n",
        "        optimizer = optim.Adam(model.parameters(), lr=lr)\n",
        "        print(f\"  Phase {phase_idx}: {n_epochs} epochs @ lr={lr:.0e}\")\n",
        "\n",
        "        for epoch in range(n_epochs):\n",
        "            global_epoch += 1\n",
        "            model.train()\n",
        "            losses = []\n",
        "\n",
        "            # This generates the random index array directly on the GPU\n",
        "            perm = torch.randperm(n_train, device=device)\n",
        "\n",
        "            for i in range(0, n_train, BATCH_SIZE):\n",
        "                # Slice the tensors directly on the GPU\n",
        "                idx = perm[i:i+BATCH_SIZE]\n",
        "                xb = X_train_gpu[idx]\n",
        "                yb = Y_train_gpu[idx]\n",
        "\n",
        "                optimizer.zero_grad()\n",
        "                loss = criterion(model(xb), yb)\n",
        "                loss.backward()\n",
        "                optimizer.step()\n",
        "                losses.append(loss.item())\n",
        "\n",
        "            train_mse = np.mean(losses)\n",
        "\n",
        "            # VALIDATION LOOP\n",
        "            model.eval()\n",
        "            vlosses = []\n",
        "            with torch.no_grad():\n",
        "                for i in range(0, n_val, BATCH_SIZE):\n",
        "                    xb = X_val_gpu[i:i+BATCH_SIZE]\n",
        "                    yb = Y_val_gpu[i:i+BATCH_SIZE]\n",
        "                    vlosses.append(criterion(model(xb), yb).item())\n",
        "            val_mse = np.mean(vlosses)\n",
        "\n",
        "            history['train_loss'].append(train_mse)\n",
        "            history['val_loss'].append(val_mse)\n",
        "\n",
        "            if global_epoch % 5 == 0 or global_epoch == total_epochs:\n",
        "                print(f\"    Epoch {global_epoch:3d}/{total_epochs} | train={train_mse:.4f} | val={val_mse:.4f}\")\n",
        "\n",
        "        # Save checkpoint\n",
        "        torch.save({'model_state': model.state_dict(), 'phase': phase_idx, 'global_epoch': global_epoch, 'history': history}, checkpoint_path)\n",
        "        print(f\"    ✓ Checkpoint saved (phase {phase_idx})\")\n",
        "\n",
        "    torch.save(model.state_dict(), final_path)\n",
        "    print(f\"  ✓ Final model → {final_path}\")\n",
        "\n",
        "    return model, history\n",
        "\n",
        "models, histories = {}, {}\n",
        "for opt_type in ['call', 'put']:\n",
        "    print(f\"\\n{'='*60}\")\n",
        "    print(f\"TRAINING MLP2 — {opt_type.upper()}\")\n",
        "    print(f\"{'='*60}\")\n",
        "    m, h = train_mlp2(data_splits[opt_type], f'mlp2_{opt_type}')\n",
        "    models[opt_type] = m\n",
        "    histories[opt_type] = h"
      ]
    },
