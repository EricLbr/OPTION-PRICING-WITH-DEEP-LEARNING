        "# ==============================================================================\n",
        "# CELL 11 — MONEYNESS & MATURITY BREAKDOWN\n",
        "# ==============================================================================\n",
        "\n",
        "for opt_type in ['call', 'put']:\n",
        "    if opt_type not in models:\n",
        "        continue\n",
        "    split   = data_splits[opt_type]\n",
        "    test_df = split['test_df']\n",
        "    Y_test  = split['Y_test']\n",
        "    y_true  = (Y_test[:, 0] + Y_test[:, 1]) / 2.0\n",
        "\n",
        "    # MLP2 predictions\n",
        "    model = models[opt_type]; model.eval()\n",
        "    with torch.no_grad():\n",
        "        pred = model(torch.tensor(split['X_test'], dtype=torch.float32)\n",
        "                     .to(DEVICE)).cpu().numpy()\n",
        "    mlp2_mid = (pred[:, 0] + pred[:, 1]) / 2.0\n",
        "\n",
        "    # Black-Scholes\n",
        "    hist_vol_arr = test_df['sigma'].values / 100.0\n",
        "    bs_prices = black_scholes(test_df['S'].values, test_df['K'].values,\n",
        "                           test_df['T'].values, test_df['r'].values,\n",
        "                           hist_vol_arr, opt_type)\n",
        "\n",
        "    # Moneyness & maturity bins\n",
        "    money = test_df['S'].values / test_df['K'].values\n",
        "    money_bins = pd.cut(money,\n",
        "                        bins=[0, 0.9, 0.95, 1.0, 1.05, 1.1, 2.0],\n",
        "                        labels=['DeepOTM', 'OTM', 'ATM-', 'ATM+', 'ITM', 'DeepITM'])\n",
        "    mat_bins = pd.cut(test_df['T'].values,\n",
        "                      bins=[0, 30/365, 90/365, 180/365, 1, 3],\n",
        "                      labels=['<30d', '30-90d', '90-180d', '180d-1y', '1-3y'])\n",
        "\n",
        "    mask = y_true > 0.01\n",
        "\n",
        "    for bin_name, bins in [('Moneyness', money_bins), ('Maturity', mat_bins)]:\n",
        "        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "        for i, (name, preds, color) in enumerate([\n",
        "            ('MLP2',          mlp2_mid,  'steelblue'),\n",
        "            ('Black-Scholes', bs_prices, 'coral'),\n",
        "        ]):\n",
        "            ax  = axes[i]\n",
        "            ape = np.abs((preds[mask] - y_true[mask]) / y_true[mask]) * 100\n",
        "            (pd.DataFrame({'bin': bins[mask], 'ape': ape})\n",
        "               .groupby('bin', observed=True)['ape']\n",
        "               .median()\n",
        "               .plot(kind='bar', ax=ax, color=color, alpha=0.8))\n",
        "            ax.set_title(f'{name} — {opt_type.upper()} MAPE by {bin_name}')\n",
        "            ax.set_ylabel('Median Abs % Error')\n",
        "            ax.tick_params(axis='x', rotation=45)\n",
        "        plt.tight_layout()\n",
        "        plt.savefig(os.path.join(MODEL_SAVE_DIR,\n",
        "                    f'{bin_name.lower()}_{opt_type}.png'), dpi=150)\n",
        "        plt.show()"
      ]
    },
